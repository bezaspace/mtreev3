  --bg-base: #1e1e2e;
  --bg-mantle: #181825;
  --bg-crust: #11111b;
  --bg-surface0: #313244;
  --bg-surface1: #45475a;
  --blue: #89b4fa;
  --teal: #94e2d5;
  --lavender: #b4befe;
  --text: #cdd6f4;
  --subtext0: #a6adc8;
  --subtext1: #6c7086;
